    {
      "name": "Register Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Diagnostics + success assertions for /api/register",
              "pm.test(\"Register: status is not 500\", function () {",
              "  pm.expect(pm.response.code, `Unexpected 500. Body: ${pm.response.text()}`).to.not.equal(500);",
              "});",
              "",
              "const code = pm.response.code;",
              "",
              "// On success, assert JSON shape includes a token-like field",
              "if (code === 200 || code === 201) {",
              "  let json = {};",
              "  try { json = pm.response.json(); } catch (e) {}",
              "",
              "  pm.test(\"Register: returns JSON\", function () {",
              "    pm.response.to.be.json;",
              "  });",
              "",
              "  pm.test(\"Register: response includes token (token or access_token)\", function () {",
              "    pm.expect(",
              "      json.token || json.access_token,",
              "      `Expected token in response. Got: ${pm.response.text()}`",
              "    ).to.exist;",
              "  });",
              "",
              "  // Common Laravel patterns: { user: {...}, token: \"...\" } OR { data: { user }, token }",
              "  pm.test(\"Register: includes user object (optional)\", function () {",
              "    const user = json.user || json.data?.user || json.data;",
              "    pm.expect(user, \"Expected user object in response\").to.exist;",
              "  });",
              "}",
              "",
              "// If validation fails, surface the errors clearly (do not mark whole run as pass)",
              "if (code >= 400 && code < 500) {",
              "  let json;",
              "  try { json = pm.response.json(); } catch (e) { json = null; }",
              "",
              "  const errors = json?.errors || json?.message || pm.response.text();",
              "",
              "  pm.test(`Register: client error details (${code})`, function () {",
              "    pm.expect.fail(`${code} Client Error: ${JSON.stringify(errors, null, 2)}`);",
              "  });",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
