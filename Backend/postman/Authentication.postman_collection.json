  "item": [
    {
      "name": "Login Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Parse JSON safely",
              "let json;",
              "try { json = pm.response.json(); } catch (e) { json = {}; }",
              "",
              "pm.test('Login response is JSON', () => {",
              "  pm.response.headers.get('Content-Type') && pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "pm.test('Login succeeded (200/201)', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "// Common token field names: token, access_token",
              "const token = json.token || json.access_token || (json.data && (json.data.token || json.data.access_token));",
              "",
              "pm.test('Auth token is present in response', () => {",
              "  pm.expect(token, 'Expected token in response at token/access_token/data.token').to.be.ok;",
              "});",
              "",
              "if (token) {",
              "  pm.environment.set('token', token);",
              "  pm.test('Saved token to environment variable: token', () => {",
              "    pm.expect(pm.environment.get('token')).to.eql(token);",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
